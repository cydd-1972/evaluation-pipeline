# OpenAI 兼容 API（add / search / answer 主链路 → MiniMax）
OPENAI_API_KEY=your_minimax_api_key_here
OPENAI_API_BASE=https://api.minimaxi.com/v1
OPENAI_MODEL=MiniMax-M2.7

# Embedding（/v1/embeddings；与 chat 分开）
# Memorax 主工程: text-embedding-v4 @ DashScope
# gptplus5 实测可用: text-embedding-3-large + dimensions=1024
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_API_KEY=your_embedding_api_key_here
OPENAI_EMBEDDING_API_BASE=https://api.gptplus5.com/v1
OPENAI_EMBEDDING_DIMENSIONS=1024

# 兼容别名
key=your_api_key_here
api_base=https://api.gptplus5.com/v1
model_name=gemini-3.1-flash-lite-preview

EVAL_DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# eval 裁判（主仓库默认 Qwen3-14B @ SiliconFlow）
EVALUATOR_API_KEY=your_siliconflow_or_dashscope_key
# 多个 key 用逗号分隔；429 时自动轮询，并发按 key 数放大（默认 cap=12）
# EVALUATOR_API_KEYS=key_a,key_b,key_c
EVALUATOR_API_BASE=https://api.siliconflow.cn/v1
EVALUATOR_MODEL=Qwen/Qwen3-14B
# Qwen3-14B @ SiliconFlow：RPM 1000，TPM 40000（同账号多 key 共享 TPM，不叠加）
# EVALUATOR_TPM_LIMIT=40000
# EVALUATOR_EST_INPUT_TOKENS=5000
# EVALUATOR_TPM_BUFFER=0.85
# EVALUATOR_CONCURRENCY_PER_KEY=1
# EVALUATOR_CONCURRENCY_MAX=2
# DashScope 备选:
# EVALUATOR_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# EVALUATOR_MODEL=qwen3-14b
